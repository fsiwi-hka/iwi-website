{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "WebDav": {
    "BaseUrl": "https://cloud.iwi-hka.de/remote.php/dav/files/system_user/Fachschaft/Systems/Information System/",
    "ConfigFileName": "appconfig.Information System.json"
  },

  "Sync": {
    "IntervalHours": 6,
    "CacheDirectory": "cache",
    "DefaultDurationSeconds": 30,
    "RefreshToken": ""
  },
  
  "Instagram": {
    "ApiUrl": "https://graph.instagram.com/me",
    "TokenFilePath": "instagram_token.txt"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://www.new.iwi-hka.de"
    ]
  }
}
